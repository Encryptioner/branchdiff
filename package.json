    "link": "pnpm link --global"
  },
  "packageManager": "pnpm@latest",
  "dependencies": {
    "commander": "^12.0.0",
    "diff": "^5.2.0",
    "express": "^4.18.0"
  },
  "engines": {
    "node": ">=18"
  }
}
