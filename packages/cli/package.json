{
  "name": "branchdiff",
  "version": "1.0.0",
  "description": "Visual file-level git branch diff in your browser",
  "keywords": [
    "git",
    "diff",
    "branch",
    "viewer",
    "cli",
    "code-review",
    "pr-review",
    "branch-compare",
    "blob-diff",
    "github"
  ],
  "author": {
    "name": "Mir Mursalin Ankur",
    "email": "mir.ankur.ruet13@gmail.com",
    "url": "https://encryptioner.github.io/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Encryptioner/branchdiff.git"
  },
  "bugs": {
    "url": "https://github.com/Encryptioner/branchdiff/issues"
  },
  "homepage": "https://github.com/Encryptioner/branchdiff#readme",
  "type": "module",
  "bin": {
    "branchdiff": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsx build.ts",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx build.ts --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "echo '\\n⚠️  Run `pnpm build` from repo root before publishing (bundles workspace packages + UI).\\n'",
    "postinstall": "node dist/index.js completion install 2>/dev/null; pnpm rebuild better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "open": "^10.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@branchdiff/git": "workspace:*",
    "@branchdiff/github": "workspace:*",
    "@branchdiff/parser": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
